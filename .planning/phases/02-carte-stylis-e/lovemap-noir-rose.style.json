{
  "version": 8,
  "name": "LoveMap Noir Rose",
  "metadata": {
    "lovemap:recipe": "02-UI-SPEC.md §Mapbox Studio (MAP-01 / D-01..D-04) — variante enrichie (plus de vie)"
  },
  "sources": {
    "composite": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8"
    },
    "mapbox-dem": {
      "type": "raster-dem",
      "url": "mapbox://mapbox.mapbox-terrain-dem-v1",
      "tileSize": 514,
      "maxzoom": 14
    }
  },
  "sprite": "mapbox://sprites/mapbox/dark-v11",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "center": [2.3522, 48.8566],
  "zoom": 12,
  "bearing": 0,
  "pitch": 0,
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#08080a" }
    },
    {
      "id": "hillshade",
      "type": "hillshade",
      "source": "mapbox-dem",
      "paint": {
        "hillshade-shadow-color": "#000000",
        "hillshade-highlight-color": "#1c1622",
        "hillshade-accent-color": "#0a0a0c",
        "hillshade-exaggeration": 0.35
      }
    },
    {
      "id": "landuse-green",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["park", "grass", "wood", "scrub", "pitch", "garden", "golf_course"], true, false],
      "paint": {
        "fill-color": "#0f1c14",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 0.9]
      }
    },
    {
      "id": "landuse-cemetery-hospital",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["cemetery", "hospital", "school"], true, false],
      "paint": { "fill-color": "#0e0e12", "fill-opacity": 0.6 }
    },
    {
      "id": "national-park",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse_overlay",
      "filter": ["==", ["get", "class"], "national_park"],
      "paint": {
        "fill-color": "#122418",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 6, 0.4, 12, 0.8]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "composite",
      "source-layer": "water",
      "paint": { "fill-color": "#143a5e" }
    },
    {
      "id": "water-shoreline",
      "type": "line",
      "source": "composite",
      "source-layer": "water",
      "minzoom": 8,
      "paint": {
        "line-color": "#2a567f",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.4, 16, 1.4],
        "line-opacity": 0.6
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "composite",
      "source-layer": "waterway",
      "minzoom": 8,
      "paint": {
        "line-color": "#1f4e7a",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 16, 3]
      }
    },
    {
      "id": "aeroway-runway",
      "type": "line",
      "source": "composite",
      "source-layer": "aeroway",
      "minzoom": 11,
      "paint": { "line-color": "#1a1820", "line-width": ["interpolate", ["linear"], ["zoom"], 11, 1, 16, 6] }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["all",
        ["==", ["geometry-type"], "LineString"],
        ["match", ["get", "class"], ["street", "street_limited", "service", "track", "pedestrian", "path", "residential"], true, false]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#1c1a1f",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 18, 7]
      }
    },
    {
      "id": "road-secondary-tertiary",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 9,
      "filter": ["all",
        ["==", ["geometry-type"], "LineString"],
        ["match", ["get", "class"], ["secondary", "tertiary"], true, false]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#2c2430",
        "line-width": ["interpolate", ["linear"], ["zoom"], 10, 0.6, 18, 9]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 7,
      "filter": ["all",
        ["==", ["geometry-type"], "LineString"],
        ["==", ["get", "class"], "primary"]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#46313e",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.8, 18, 11]
      }
    },
    {
      "id": "road-motorway-casing",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 5,
      "filter": ["all",
        ["==", ["geometry-type"], "LineString"],
        ["match", ["get", "class"], ["motorway", "trunk"], true, false]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#5e2f47",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1.6, 18, 16],
        "line-opacity": 0.7,
        "line-blur": 1
      }
    },
    {
      "id": "road-motorway-trunk",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 5,
      "filter": ["all",
        ["==", ["geometry-type"], "LineString"],
        ["match", ["get", "class"], ["motorway", "trunk"], true, false]
      ],
      "layout": { "line-cap": "round", "line-join": "round" },
      "paint": {
        "line-color": "#4a2f3c",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.9, 18, 12]
      }
    },
    {
      "id": "rail",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["all",
        ["==", ["geometry-type"], "LineString"],
        ["match", ["get", "class"], ["major_rail", "minor_rail"], true, false]
      ],
      "paint": {
        "line-color": "#242029",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 2],
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "composite",
      "source-layer": "building",
      "minzoom": 13,
      "maxzoom": 15.5,
      "filter": ["==", ["geometry-type"], "Polygon"],
      "paint": {
        "fill-color": "#14111c",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0, 14.5, 0.8]
      }
    },
    {
      "id": "building-3d",
      "type": "fill-extrusion",
      "source": "composite",
      "source-layer": "building",
      "minzoom": 15,
      "filter": ["all", ["==", ["geometry-type"], "Polygon"], ["==", ["get", "extrude"], "true"]],
      "paint": {
        "fill-extrusion-color": [
          "interpolate", ["linear"], ["get", "height"],
          0, "#16121f",
          40, "#241a30",
          120, "#33233f"
        ],
        "fill-extrusion-height": ["interpolate", ["linear"], ["zoom"], 15, 0, 15.5, ["get", "height"]],
        "fill-extrusion-base": ["get", "min_height"],
        "fill-extrusion-opacity": 0.85
      }
    },
    {
      "id": "admin-country",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "filter": ["all", ["==", ["get", "admin_level"], 0], ["==", ["get", "maritime"], "false"]],
      "paint": {
        "line-color": "#3e3644",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.6, 10, 1.4]
      }
    },
    {
      "id": "admin-region",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "minzoom": 4,
      "filter": ["all", ["==", ["get", "admin_level"], 1], ["==", ["get", "maritime"], "false"]],
      "paint": {
        "line-color": "#2a2632",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 0.4, 10, 1],
        "line-dasharray": [2, 2]
      }
    },
    {
      "id": "poi-dot",
      "type": "circle",
      "source": "composite",
      "source-layer": "poi_label",
      "minzoom": 14,
      "filter": ["<=", ["get", "filterrank"], 3],
      "paint": {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 14, 1.4, 18, 3],
        "circle-color": "#ff2d87",
        "circle-opacity": ["interpolate", ["linear"], ["zoom"], 14, 0.35, 16, 0.6],
        "circle-blur": 0.3
      }
    },
    {
      "id": "road-label-major",
      "type": "symbol",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["all",
        ["==", ["geometry-type"], "LineString"],
        ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary", "tertiary"], true, false]
      ],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 18, 13],
        "text-letter-spacing": 0.02
      },
      "paint": {
        "text-color": "#c0aeb8",
        "text-halo-color": "#000000",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "poi_label",
      "minzoom": 15,
      "filter": ["<=", ["get", "filterrank"], 2],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 15, 9, 18, 12],
        "text-offset": [0, 0.9],
        "text-anchor": "top",
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#a88a96",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    },
    {
      "id": "transit-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "transit_stop_label",
      "minzoom": 14,
      "filter": ["<=", ["get", "filterrank"], 1],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": 10,
        "text-offset": [0, 0.8],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#7a8a96",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    },
    {
      "id": "water-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "natural_label",
      "minzoom": 10,
      "filter": ["match", ["get", "class"], ["bay", "sea", "ocean", "water", "river", "canal", "lake"], true, false],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Italic", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 10, 16, 14],
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#7a5a6a",
        "text-halo-color": "#000000",
        "text-halo-width": 0.8
      }
    },
    {
      "id": "park-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "natural_label",
      "minzoom": 13,
      "filter": ["match", ["get", "class"], ["park", "wood", "national_park"], true, false],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Italic", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10, 16, 13]
      },
      "paint": {
        "text-color": "#5e7a64",
        "text-halo-color": "#000000",
        "text-halo-width": 0.8
      }
    },
    {
      "id": "place-neighborhood",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "minzoom": 12,
      "maxzoom": 16,
      "filter": ["==", ["get", "class"], "settlement_subdivision"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 14],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.08,
        "text-max-width": 7
      },
      "paint": {
        "text-color": "#9a9098",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-settlement",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "maxzoom": 15,
      "filter": ["==", ["get", "class"], "settlement"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          4, ["interpolate", ["linear"], ["get", "symbolrank"], 1, 13, 9, 10],
          12, ["interpolate", ["linear"], ["get", "symbolrank"], 1, 22, 12, 13]
        ],
        "text-letter-spacing": 0.02,
        "text-max-width": 7
      },
      "paint": {
        "text-color": "#cdc5cb",
        "text-halo-color": "#000000",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "place-region",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "minzoom": 4,
      "maxzoom": 8,
      "filter": ["==", ["get", "class"], "region"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 8, 14],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.1
      },
      "paint": {
        "text-color": "#6a646e",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "maxzoom": 7,
      "filter": ["==", ["get", "class"], "country"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_fr"], ["get", "name"]],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 2, 11, 6, 17],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12
      },
      "paint": {
        "text-color": "#b0a8b0",
        "text-halo-color": "#000000",
        "text-halo-width": 1
      }
    }
  ]
}
